{
    "name": "kamz8/laravel-batch-orchestrator",
    "description": "Dynamic chunking and batch orchestration for Laravel queued jobs.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2|^8.3",
        "illuminate/bus": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Kamz8\\BatchOrchestrator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kamz8\\BatchOrchestrator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kamz8\\BatchOrchestrator\\BatchOrchestratorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
