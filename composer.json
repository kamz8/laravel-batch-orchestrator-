{
    "name": "kamz8/laravel-batch-orchestrator",
    "description": "Dynamic chunking and batch orchestration for Laravel queued jobs.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kamil Żmijowski",
            "homepage": "https://github.com/kamz8"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "illuminate/bus": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Kamz8\\BatchOrchestrator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kamz8\\BatchOrchestrator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kamz8\\BatchOrchestrator\\BatchOrchestratorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
